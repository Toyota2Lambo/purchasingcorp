# ============================================================
# pricing-engine — environment
# Copy to `.env` (gitignored) and paste your keys. In CI, set these
# as GitHub Actions secrets instead — you do NOT need a .env there.
# ============================================================

# --- eBay (PRIMARY source) -----------------------------------
# Register a "Production" app at https://developer.ebay.com/my/keys
# (free developer account). Copy the App ID (Client ID) and
# Cert ID (Client Secret) here. Client-credentials OAuth only — no
# user login, no redirect URL needed for read-only market data.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=

# 'production' (default) or 'sandbox'
EBAY_ENV=production
# eBay marketplace to query
EBAY_MARKETPLACE_ID=EBAY_US
# Set to 1 ONLY after eBay grants Marketplace Insights access (real
# sold prices). Otherwise the engine uses Browse active listings as a
# proxy and tags the data so you know to compensate via margins.
EBAY_MARKETPLACE_INSIGHTS=0

# --- Best Buy (REFERENCE anchor) -----------------------------
# Free API key from https://developer.bestbuy.com (Products API).
# Returns NEW retail prices — used as a reference/ceiling anchor, NOT
# as a used/sold comp. By default Best Buy prices are recorded in the
# audit trail but do NOT move the offer (config.sources.bestbuy
# .useAsBasis=false). Set BESTBUY_ENABLED=1 to turn the source on.
BESTBUY_API_KEY=
BESTBUY_ENABLED=0

# --- Competitor scrapers (FALLBACK) --------------------------
# Off unless set to 1 AND you've added verified site adapters in
# config.js (sources.competitors.sites). robots.txt is always obeyed.
COMPETITORS_ENABLED=0

# --- Optional notifications ----------------------------------
# Reuse the same Discord webhook the social pipeline uses, if you want
# a ping when a run finishes or flags a lot of "needs manual price".
DISCORD_WEBHOOK_URL=
